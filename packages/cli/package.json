{
  "name": "depress",
  "version": "0.1.0",
  "description": "De-press yourself. WordPress to Astro + Keystatic migration tool.",
  "type": "module",
  "bin": {
    "depress": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
