  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/depress-dev/depress.git",
    "directory": "packages/cli"
  },
  "dependencies": {
    "@depress/core": "*",
    "@depress/wp-migrate": "*",
    "commander": "^12.0.0",
    "inquirer": "^9.0.0",
    "chalk": "^5.0.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/inquirer": "^9.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
