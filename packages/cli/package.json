{
  "name": "@depress-org/depress",
  "version": "0.1.0",
  "description": "De-press yourself. Migrate any WordPress blog to Astro + Keystatic in minutes. Free hosting forever.",
  "type": "module",
  "bin": {
    "depress": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "wordpress",
    "migration",
    "astro",
    "keystatic",
    "static-site",
    "cms",
    "cli",
    "blog",
    "wp2md",
    "cloudflare"
  ],
  "author": "depress-org",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/depress-org/depress.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/depress-org/depress#readme",
  "bugs": {
    "url": "https://github.com/depress-org/depress/issues"
  },
  "dependencies": {
    "@depress-org/core": "*",
    "@depress-org/wp-migrate": "*",
    "chalk": "^5.0.0",
    "commander": "^12.0.0",
    "inquirer": "^9.0.0",
    "ora": "^8.0.0",
    "wordpress-export-to-markdown": "^3.0.4"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
