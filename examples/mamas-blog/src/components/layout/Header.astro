---
const nav = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog' },
]

const current = Astro.url.pathname
---

<header class="border-b border-gray-200 bg-white sticky top-0 z-10">
  <nav class="container mx-auto px-4 max-w-3xl flex items-center justify-between h-14">
    <a href="/" class="text-lg font-semibold text-gray-900 hover:text-gray-700 transition-colors">
      Blog
    </a>
    <ul class="flex gap-6">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              class={`text-sm transition-colors ${
                current === item.href || (item.href !== '/' && current.startsWith(item.href))
                  ? 'text-gray-900 font-medium'
                  : 'text-gray-500 hover:text-gray-900'
              }`}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
