{
  "name": "@depress-org/core",
  "version": "0.1.0",
  "description": "Shared types for depress — WordPress to Astro + Keystatic migration tool",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/depress-org/depress.git",
    "directory": "packages/core"
  },
  "keywords": [
    "wordpress",
    "astro",
    "keystatic",
    "migration"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
