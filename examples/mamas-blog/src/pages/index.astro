---
import BaseLayout from '../layouts/BaseLayout.astro'
import ArticleCard from '../components/ui/ArticleCard.astro'
import { getCollection } from 'astro:content'

const articles = (await getCollection('articles'))
  .sort(
    (a, b) =>
      new Date(b.data.publishedAt ?? 0).getTime() - new Date(a.data.publishedAt ?? 0).getTime(),
  )
  .slice(0, 6)
---

<BaseLayout title="Home" description="Thoughtful articles on psychology and wellbeing.">
  <section class="mb-12">
    <h1 class="text-4xl font-bold text-gray-900 mb-4 font-serif">Welcome</h1>
    <p class="text-lg text-gray-600 leading-relaxed">
      Thoughtful articles on psychology, wellbeing, and the inner life.
    </p>
  </section>

  {
    articles.length > 0 ? (
      <section>
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-semibold text-gray-900">Latest Articles</h2>
          <a href="/blog" class="text-sm text-blue-600 hover:text-blue-800 transition-colors">
            View all →
          </a>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          {articles.map((article) => (
            <ArticleCard
              title={article.data.title}
              slug={article.slug}
              excerpt={article.data.excerpt}
              publishedAt={article.data.publishedAt}
              category={article.data.category}
            />
          ))}
        </div>
      </section>
    ) : (
      <div class="text-center py-20 text-gray-400 border border-dashed border-gray-200 rounded-xl">
        <p class="text-lg mb-2">No articles yet.</p>
        <p class="text-sm">
          Run <code class="bg-gray-100 px-2 py-0.5 rounded text-gray-600">npx depress migrate</code>{' '}
          to import your WordPress content.
        </p>
      </div>
    )
  }
</BaseLayout>
