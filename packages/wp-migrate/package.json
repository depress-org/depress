{
  "name": "@depress-org/wp-migrate",
  "version": "0.1.0",
  "description": "WordPress migration engine for depress — converts WXR exports to Astro + Keystatic",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "dependencies": {
    "@depress-org/core": "*",
    "chalk": "^5.0.0",
    "fast-xml-parser": "^4.0.0",
    "gray-matter": "^4.0.0",
    "slugify": "^1.6.0",
    "turndown": "^7.0.0",
    "wordpress-export-to-markdown": "^3.0.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/turndown": "^5.0.0",
    "typescript": "^5.4.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/depress-org/depress.git",
    "directory": "packages/wp-migrate"
  },
  "keywords": [
    "wordpress",
    "migration",
    "astro",
    "keystatic",
    "wxr",
    "markdown"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
